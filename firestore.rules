rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasActiveAccess(ownerUid, userEmail) {
      return exists(/databases/$(database)/documents/userAccess/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userAccess/$(request.auth.uid)).data.ownerUid == ownerUid &&
        get(/databases/$(database)/documents/userAccess/$(request.auth.uid)).data.userEmail == userEmail &&
        get(/databases/$(database)/documents/userAccess/$(request.auth.uid)).data.status == 'active';
    }
    
    // User Access Collection - Account managers control user access
    match /userAccess/{accessId} {
      // Only account owner can create, read, update, or delete user access
      allow read: if isOwner(resource.data.ownerUid);
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(resource.data.ownerUid);
      allow delete: if isOwner(resource.data.ownerUid);
    }
    
    // Wine Monitoring States - User data and projects
    match /wineMonitoringStates/{userId} {
      // Owner can always read/write their own data
      allow read, write: if isOwner(userId);
      
      // Users with active access can read
      allow read: if isAuthenticated() && 
        exists(/databases/$(database)/documents/userAccess/$(userId + '_' + request.auth.email)) &&
        get(/databases/$(database)/documents/userAccess/$(userId + '_' + request.auth.email)).data.status == 'active';
      
      // Users with edit permission can write
      allow write: if isAuthenticated() && 
        exists(/databases/$(database)/documents/userAccess/$(userId + '_' + request.auth.email)) &&
        get(/databases/$(database)/documents/userAccess/$(userId + '_' + request.auth.email)).data.status == 'active' &&
        get(/databases/$(database)/documents/userAccess/$(userId + '_' + request.auth.email)).data.allowEdit == true;
    }
    
    // Site Passwords - User authentication data
    match /userSitePasswords/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    // Legacy: Project Access Invites (deprecated but kept for backward compatibility)
    match /projectAccessInvites/{inviteId} {
      // Only account owner can manage invites
      allow read: if isAuthenticated() && (
        isOwner(resource.data.ownerUid) || 
        request.auth.email == resource.data.inviteeEmail
      );
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isOwner(resource.data.ownerUid);
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
