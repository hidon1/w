rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(ownerUid) {
      return isAuthenticated() && request.auth.uid == ownerUid;
    }
    function isLinkedTo(ownerUid) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/links/$(ownerUid)_$(request.auth.uid));
    }

    // ספריית בעלי חשבון (שדות מינימליים) כדי לאפשר חיפוש בעלים לפי מייל לצורך קישור
    match /owners/{ownerUid} {
      // קריאה מותרת לכל משתמש מחובר כדי לאפשר חיפוש לפי מייל
      allow read: if isAuthenticated();
      // כתיבה רק ע"י הבעלים (הקוד יוצר/מעדכן פרופיל בסיסי לאחר התחברות)
      allow create, update, delete: if isOwner(ownerUid);
    }

    // רשימת מיילים שמורשים להתקשר לחשבון הבעלים
    match /allowlists/{ownerUid}/emails/{email} {
      // ניהול הרשאות אך ורק ע"י הבעלים
      allow read, write: if isOwner(ownerUid);
    }

    // קישורים בין בעל חשבון (owner) למשתמש מקושר (member)
    match /links/{ownerUid}_{memberUid} {
      // קריאה: הבעלים או המשתמש המקושר
      allow read: if isOwner(ownerUid) || (isAuthenticated() && request.auth.uid == memberUid);

      // יצירה:
      // 1) הבעלים יכול ליצור קישור ישיר לעצמו ולמשתמש
      // 2) המשתמש יכול ליצור קישור אם מיילו מופיע ב-allowlist של הבעלים
      allow create: if
        isOwner(ownerUid) ||
        (isAuthenticated() && request.auth.uid == memberUid &&
         exists(/databases/$(database)/documents/allowlists/$(ownerUid)/emails/$(request.auth.token.email)));

      // מחיקה: רק הבעלים
      allow delete: if isOwner(ownerUid);

      // עדכון אסור (כדי להקל על אכיפת הרשאות)
      allow update: if false;
    }

    // מסמכי פרופיל משתמש (אופציונלי)
    match /users/{userUid} {
      allow read, write: if isOwner(userUid) || isLinkedTo(userUid);
    }

    // כל דאטה של בעל חשבון נמצא תחת userData/{ownerUid}/...
    match /userData/{ownerUid}/{document=**} {
      allow read, write: if isOwner(ownerUid) || isLinkedTo(ownerUid);
    }
  }
}
